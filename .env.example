# ==============================================================================
# Jarvis Local Environment Configurations Example
#
# IMPORTANT: Copy this file to '.env' (or '.env.local') to configure your local
# instance. Never commit API keys or real secrets to version control.
# ==============================================================================

# Application Environment
NODE_ENV=development
JARVIS_APP_ID=com.jarvis.desktop

# Storage Paths (Defined by Storage Policy)
# Always use the absolute path to your external SSD for data-heavy structures.
JARVIS_EXTERNAL_ROOT="/Volumes/HP P500/Jarvis"
JARVIS_INTERNAL_CONFIG="~/Library/Application Support/Jarvis"

# API Keys (Stored locally, never committed)
# These will be loaded securely. Do not store these in plain text on the external SSD!
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
ELEVENLABS_API_KEY=""

# Security configuration
ENCRYPTION_KEY_ID="com.jarvis.secrets.master-key"
